<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Atelia.TextAdv</RootNamespace>
    <AssemblyName>Atelia.TextAdv</AssemblyName>
    <!-- pmux-host 通过绝对路径加载 DLL，需要把 NuGet 依赖也复制到输出目录 -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>Atelia.TextAdv.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.6" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\StateJournal\StateJournal.csproj" />
    <ProjectReference Include="..\..\src\TextEditScript\TextEditScript.csproj" />
    <ProjectReference Include="..\Completion.Abstractions\Completion.Abstractions.csproj" />
    <ProjectReference Include="..\Completion.Tools\Completion.Tools.csproj" />
    <ProjectReference Include="..\Completion\Completion.csproj" />
  </ItemGroup>
</Project>
